        "tiddlywiki/highlight",
        "rimir/components",
        "rimir/core-hook",
        "rimir/doc-template",
        "rimir/file-upload",
        "rimir/filesystem-watcher",
        "rimir/git-int",
        "rimir/json-dsl",
        "rimir/orga",
        "rimir/orga-tools",
        "rimir/realms",
        "rimir/runner",
        "rimir/file-pipeline",
        "rimir/theme",
